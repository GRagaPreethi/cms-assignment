# ============================================================
# Headless CMS — Environment Variables Template
# Copy this file to .env and fill in the values.
# ============================================================

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_at_least_32_chars
JWT_EXPIRES_IN=7d

# MongoDB (overridden by docker-compose for container environments)
MONGO_URI=mongodb://localhost:27017/headless-cms

# Backend
PORT=5000
NODE_ENV=production

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Admin CMS (Vite build-time variable)
VITE_API_URL=http://localhost:5000

# Public Frontend (NextJS)
API_URL=http://localhost:5000
NEXT_PUBLIC_API_URL=http://localhost:5000
